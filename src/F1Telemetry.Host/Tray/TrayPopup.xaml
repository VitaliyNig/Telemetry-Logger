<UserControl x:Class="F1Telemetry.Tray.TrayPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <SolidColorBrush x:Key="BgPrimary"   Color="#0D1117"/>
        <SolidColorBrush x:Key="BgTertiary"  Color="#21262D"/>
        <SolidColorBrush x:Key="BorderColor" Color="#30363D"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8B949E"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#6E7681"/>
        <SolidColorBrush x:Key="Accent"      Color="#9B3FF5"/>
        <SolidColorBrush x:Key="StatusGreen" Color="#3FB950"/>
        <SolidColorBrush x:Key="DangerRed"   Color="#F85149"/>

        <!-- Base menu-item button -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"    Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="Transparent"
                                CornerRadius="6" Padding="12,9">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{StaticResource BgTertiary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Exit button: dimmer text, turns red on hover -->
        <Style x:Key="ExitButton" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource DangerRed}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- Outer margin gives room for the drop-shadow to render -->
    <Border Margin="14" Width="280"
            Background="{StaticResource BgPrimary}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1" CornerRadius="12"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4"
                              Opacity="0.65" Color="#000000"/>
        </Border.Effect>

        <StackPanel>
            <!-- ───── Header ───── -->
            <Grid Margin="16,14,16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Viewbox Grid.Column="0" Width="28" Height="28"
                         Margin="0,0,12,0" VerticalAlignment="Center">
                    <Canvas Width="256" Height="256">
                        <Path Fill="{StaticResource Accent}"
                              Data="M74 217.193L38.3682 162.364L62.7363 107.536H2.73633L27.1045 52.707H162.104L168.197 39H228.197L222.104 52.707L197.736 107.536H122.736L74 217.193ZM173.368 162.364H218.368L254 217.193H89L131.645 121.243H191.645L173.368 162.364Z"/>
                    </Canvas>
                </Viewbox>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Telemetry Logger"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <Ellipse x:Name="StatusDot" Width="7" Height="7"
                                 Fill="{StaticResource StatusGreen}"
                                 Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Text="Running"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{StaticResource BorderColor}"/>

            <!-- ───── Connection info ───── -->
            <StackPanel Margin="16,12,16,12">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="HTTP" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="HttpUrl" Grid.Column="1"
                               FontSize="12" FontFamily="Consolas"
                               Foreground="{StaticResource TextSecondary}"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="UDP" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="UdpInfo" Grid.Column="1"
                               FontSize="12" FontFamily="Consolas"
                               Foreground="{StaticResource TextSecondary}"/>
                </Grid>
            </StackPanel>

            <Border Height="1" Background="{StaticResource BorderColor}"/>

            <!-- ───── Actions ───── -->
            <StackPanel Margin="6,4,6,4">
                <Button Style="{StaticResource MenuButton}" Click="OpenWebInterface_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Open Web Interface" FontSize="13"/>
                        <TextBlock Grid.Column="1" Text="&#x2192;" FontSize="13"
                                   Foreground="{StaticResource TextMuted}"/>
                    </Grid>
                </Button>
                <Button Style="{StaticResource MenuButton}" Click="OpenDataFolder_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Open Data Folder" FontSize="13"/>
                        <TextBlock Grid.Column="1" Text="&#x2192;" FontSize="13"
                                   Foreground="{StaticResource TextMuted}"/>
                    </Grid>
                </Button>
            </StackPanel>

            <Border Height="1" Background="{StaticResource BorderColor}"/>

            <!-- ───── Exit ───── -->
            <StackPanel Margin="6,4,6,6">
                <Button Style="{StaticResource ExitButton}" Click="Exit_Click">
                    <TextBlock Text="Exit" FontSize="13"/>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
